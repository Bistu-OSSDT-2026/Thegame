<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <title>贪吃蛇</title>
  <style>
    body { display:flex; align-items:center; justify-content:center; height:100vh; margin:0; background:#111; color:#eee; font-family:Arial, sans-serif; }
    #game { background:#222; box-shadow:0 0 20px rgba(0,0,0,.8); }
    .info { position:absolute; top:12px; left:12px; color:#fff; font-size:14px; }
    .footer { position:fixed; bottom:10px; left:10px; color:#aaa; font-size:13px; }
  </style>
</head>
<body>
  <div class="info">按方向键移动 • 空格重启</div>
  <canvas id="game" width="400" height="400"></canvas>
  <div class="footer">Score: <span id="score">0</span></div>

<script>
(() => {
  const canvas = document.getElementById('game');
  const ctx = canvas.getContext('2d');
  const scoreEl = document.getElementById('score');

  const TILE = 20; // 格子大小（像素）
  const COLS = canvas.width / TILE;
  const ROWS = canvas.height / TILE;

  let snake;
  let dir;
  let nextDir;
  let food;
  let running;
  let score;
  let speed = 120; // 初始帧间隔(ms)
  let timerId;

  function reset() {
    snake = [{x: Math.floor(COLS/2), y: Math.floor(ROWS/2)}];
    dir = {x: 1, y: 0};
    nextDir = dir;
    placeFood();
    running = true;
    score = 0;
    speed = 120;
    scoreEl.textContent = score;
    if (timerId) clearInterval(timerId);
    timerId = setInterval(tick, speed);
  }

  function placeFood() {
    while (true) {
      const pos = { x: Math.floor(Math.random()*COLS), y: Math.floor(Math.random()*ROWS) };
      if (!snake.some(s => s.x === pos.x && s.y === pos.y)) {
        food = pos;
        return;
      }
    }
  }

  function tick() {
    // apply nextDir if not opposite
    if (!(nextDir.x === -dir.x && nextDir.y === -dir.y)) dir = nextDir;

    const head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };

    // 碰墙 -> 游戏结束
    if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) {
      gameOver();
      return;
    }

    // 撞到自己 -> 游戏结束
    if (snake.some(s => s.x === head.x && s.y === head.y)) {
      gameOver();
      return;
    }

    snake.unshift(head);

    // 吃到食物
    if (head.x === food.x && head.y === food.y) {
      score += 10;
      scoreEl.textContent = score;
      placeFood();
      // 提速（可调）
      speed = Math.max(40, speed - 2);
      clearInterval(timerId);
      timerId = setInterval(tick, speed);
    } else {
      snake.pop();
    }

    draw();
  }

  function gameOver() {
    running = false;
    clearInterval(timerId);
    draw(true);
  }

  function draw(gameOverFlag = false) {
    // 背景
    ctx.fillStyle = '#121212';
    ctx.fillRect(0,0,canvas.width,canvas.height);

    // 网格(可选，轻微线)
    ctx.strokeStyle = 'rgba(255,255,255,0.03)';
    for (let i=0;i<=COLS;i++){
      ctx.beginPath(); ctx.moveTo(i*TILE,0); ctx.lineTo(i*TILE,canvas.height); ctx.stroke();
    }
    for (let j=0;j<=ROWS;j++){
      ctx.beginPath(); ctx.moveTo(0,j*TILE); ctx.lineTo(canvas.width,j*TILE); ctx.stroke();
    }

    // 食物
    ctx.fillStyle = '#e74c3c';
    roundRectFill(food.x*TILE, food.y*TILE, TILE, TILE, 4);

    // 蛇身体
    for (let i=0;i<snake.length;i++) {
      const s = snake[i];
      if (i === 0) ctx.fillStyle = '#2ecc71';
      else ctx.fillStyle = '#27ae60';
      roundRectFill(s.x*TILE, s.y*TILE, TILE, TILE, 4);
    }

    if (gameOverFlag) {
      ctx.fillStyle = 'rgba(0,0,0,0.6)';
      ctx.fillRect(0, canvas.height/2 - 40, canvas.width, 80);
      ctx.fillStyle = '#fff';
      ctx.font = '20px Arial';
      ctx.textAlign = 'center';
      ctx.fillText('游戏结束 — 按空格重启', canvas.width/2, canvas.height/2 + 7);
    }
  }

  function roundRectFill(x, y, w, h, r) {
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.arcTo(x + w, y, x + w, y + h, r);
    ctx.arcTo(x + w, y + h, x, y + h, r);
    ctx.arcTo(x, y + h, x, y, r);
    ctx.arcTo(x, y, x + w, y, r);
    ctx.closePath();
    ctx.fill();
  }

  // 键盘控制
  window.addEventListener('keydown', e => {
    if (e.key === 'ArrowUp' || e.key === 'w') nextDir = {x:0,y:-1};
    else if (e.key === 'ArrowDown' || e.key === 's') nextDir = {x:0,y:1};
    else if (e.key === 'ArrowLeft' || e.key === 'a') nextDir = {x:-1,y:0};
    else if (e.key === 'ArrowRight' || e.key === 'd') nextDir = {x:1,y:0};
    else if (e.code === 'Space') {
      if (!running) reset();
      else { /* 暂停/继续 */ running = !running; if (running) timerId = setInterval(tick, speed); else clearInterval(timerId); }
      e.preventDefault();
    }
  });

  // 支持页面点击开始/重启
  canvas.addEventListener('click', () => { if (!running) reset(); });

  // 首次启动
  reset();
})();
</script>
</body>
</html>
