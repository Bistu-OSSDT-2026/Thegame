<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <title>卡通风格贪吃蛇</title>
  <style>
    body { display:flex; align-items:center; justify-content:center; height:100vh; margin:0; background:#87CEEB; color:#222; font-family:Arial, sans-serif; }
    #wrap { display:flex; flex-direction:column; align-items:center; gap: 15px; position:relative; }
    
    /* 1. 将提示词移到地图外面，并美化为卡通小卡片样式 */
    .info { 
      background: rgba(255, 255, 255, 0.85); 
      color: #2c3e50; 
      padding: 8px 20px; 
      border-radius: 20px; 
      font-size: 15px; 
      font-weight: bold;
      box-shadow: 0 4px 15px rgba(0,0,0,0.15);
      user-select: none; 
      border: 2px solid #5b3e20;
    }
    
    #game { background:transparent; box-shadow:0 8px 30px rgba(0,0,0,0.5); border-radius:8px; display:block; }
    .footer { position:fixed; bottom:10px; left:10px; color:#222; font-size:13px; }
  </style>
</head>
<body>
  <div id="wrap">
    <div class="info">按方向键移动 • 空格重启</div>
    <canvas id="game" width="600" height="600"></canvas>
  </div>
  <div class="footer">Score: <span id="score">0</span></div>

<script>
(() => {
  const canvas = document.getElementById('game');
  const ctx = canvas.getContext('2d');
  const scoreEl = document.getElementById('score');

  const TILE = 20; // 格子大小（像素）
  const COLS = canvas.width / TILE;
  const ROWS = canvas.height / TILE;

  // Game state
  let snake, dir, nextDir, food, running, score, speed, timerId;

  // Background state (cartoon)
  let clouds = [];
  const cloudCount = 5;
  let bgSeed = Math.random()*1000;

  function resetBackground() {
    clouds = [];
    for (let i = 0; i < cloudCount; i++) {
      clouds.push({
        x: Math.random() * canvas.width,
        y: 30 + Math.random() * 80,
        scale: 0.8 + Math.random() * 0.8,
        speed: 0.2 + Math.random() * 0.6
      });
    }
  }

  function reset() {
    const startX = Math.floor(COLS / 2);
    const startY = Math.floor(ROWS / 2);
    snake = [
      {x: startX, y: startY},       
      {x: startX - 1, y: startY},   
      {x: startX - 2, y: startY}    
    ];
    
    dir = {x: 1, y: 0};
    nextDir = dir;
    placeFood();
    running = true;
    score = 0;
    speed = 120;
    scoreEl.textContent = score;
    if (timerId) clearInterval(timerId);
    timerId = setInterval(tick, speed);
    resetBackground();
  }

  function placeFood() {
    while (true) {
      const pos = { x: Math.floor(Math.random()*COLS), y: Math.floor(Math.random()*ROWS) };
      if (!snake.some(s => s.x === pos.x && s.y === pos.y)) {
        food = pos;
        return;
      }
    }
  }

  function tick() {
    for (const c of clouds) {
      c.x += c.speed;
      if (c.x - 60 * c.scale > canvas.width) c.x = -80 * c.scale;
    }

    if (!(nextDir.x === -dir.x && nextDir.y === -dir.y)) dir = nextDir;

    const head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };

    if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) {
      gameOver();
      return;
    }

    if (snake.some(s => s.x === head.x && s.y === head.y)) {
      gameOver();
      return;
    }

    snake.unshift(head);

    if (head.x === food.x && head.y === food.y) {
      score += 10;
      scoreEl.textContent = score;
      placeFood();
      speed = Math.max(40, speed - 2);
      clearInterval(timerId);
      timerId = setInterval(tick, speed);
    } else {
      snake.pop();
    }

    draw();
  }

  function gameOver() {
    running = false;
    clearInterval(timerId);
    draw(true);
  }

  function drawBackground() {
    const g = ctx.createLinearGradient(0, 0, 0, canvas.height);
    g.addColorStop(0, '#87CEEB'); 
    g.addColorStop(0.6, '#A0E9FF'); 
    g.addColorStop(1, '#D6F7E8'); 
    ctx.fillStyle = g;
    roundRectFillPixels(0, 0, canvas.width, canvas.height, 8);
    ctx.fill();

    drawSun(60, 60, 36);
    drawHills();
    for (const c of clouds) drawCloud(c.x, c.y, c.scale);
    drawGrassStrip();
  }

  function drawSun(x, y, r) {
    const grad = ctx.createRadialGradient(x, y, r*0.2, x, y, r*1.8);
    grad.addColorStop(0, 'rgba(255,240,100,0.9)');
    grad.addColorStop(0.6, 'rgba(255,200,60,0.6)');
    grad.addColorStop(1, 'rgba(255,200,60,0.0)');
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.arc(x, y, r*1.8, 0, Math.PI*2);
    ctx.fill();

    ctx.fillStyle = '#FFD54A';
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI*2);
    ctx.fill();

    ctx.fillStyle = '#fff';
    ctx.beginPath(); ctx.arc(x-8, y-4, 4, 0, Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.arc(x+4, y-4, 3, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = '#5B3E20';
    ctx.beginPath(); ctx.arc(x-7, y-3.5, 1.5, 0, Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.arc(x+4.5, y-3.3, 1.2, 0, Math.PI*2); ctx.fill();
    
    ctx.strokeStyle = 'rgba(91,62,32,0.9)';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.arc(x-2, y+6, 8, 0.1*Math.PI, 0.9*Math.PI);
    ctx.stroke();
  }

  function drawHills() {
    ctx.fillStyle = '#9EE6A9';
    ctx.beginPath();
    ctx.moveTo(-50, canvas.height*0.6 + 30);
    ctx.quadraticCurveTo(canvas.width * 0.2, canvas.height * 0.35, canvas.width * 0.45, canvas.height*0.6 + 30);
    ctx.quadraticCurveTo(canvas.width * 0.65, canvas.height * 0.3, canvas.width * 0.95, canvas.height*0.6 + 30);
    ctx.lineTo(canvas.width+50, canvas.height+50);
    ctx.lineTo(-50, canvas.height+50);
    ctx.closePath();
    ctx.fill();

    ctx.fillStyle = '#6FD06A';
    ctx.beginPath();
    ctx.moveTo(-50, canvas.height*0.75 + 20);
    ctx.quadraticCurveTo(canvas.width * 0.25, canvas.height * 0.55, canvas.width * 0.55, canvas.height*0.75 + 10);
    ctx.quadraticCurveTo(canvas.width * 0.8, canvas.height * 0.45, canvas.width * 1.15, canvas.height*0.75 + 25);
    ctx.lineTo(canvas.width+50, canvas.height+50);
    ctx.lineTo(-50, canvas.height+50);
    ctx.closePath();
    ctx.fill();

    for (let i=0;i<9;i++) {
      const tx = (i*70 + 40 + (Math.sin((bgSeed+i)*0.3)*10)) % (canvas.width+20) - 10;
      drawTree(tx, canvas.height*0.72 + (i%2?6:-6));
    }
  }

  function drawTree(x, baseY) {
    ctx.fillStyle = '#8B5A2B';
    ctx.fillRect(x-4, baseY-6, 8, 12);
    ctx.fillStyle = '#2EA44F';
    ctx.beginPath(); ctx.ellipse(x, baseY-8, 18, 12, 0, 0, Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.ellipse(x-6, baseY-18, 14, 10, -0.2, 0, Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.ellipse(x+6, baseY-18, 14, 10, 0.2, 0, Math.PI*2); ctx.fill();
  }

  function drawCloud(x, y, s=1) {
    ctx.fillStyle = '#FFFFFF';
    ctx.beginPath();
    const w = 70 * s;
    const h = 30 * s;
    ctx.ellipse(x, y, w*0.5, h*0.6, 0, 0, Math.PI*2);
    ctx.ellipse(x - w*0.28, y + 2*s, w*0.38, h*0.5, 0, 0, Math.PI*2);
    ctx.ellipse(x + w*0.3, y + 2*s, w*0.34, h*0.5, 0, 0, Math.PI*2);
    ctx.fill();

    ctx.strokeStyle = 'rgba(200,200,200,0.35)';
    ctx.lineWidth = 1;
    ctx.stroke();
  }

  function drawGrassStrip() {
    const top = canvas.height - 60;
    ctx.fillStyle = '#4AC26B';
    ctx.fillRect(0, top, canvas.width, 60);

    ctx.fillStyle = '#3FA45A';
    for (let x = -10; x < canvas.width; x += 8) {
      const h = 8 + (Math.sin((x+bgSeed)*0.12)+1)*4;
      ctx.beginPath();
      ctx.moveTo(x, top+60);
      ctx.quadraticCurveTo(x+4, top+60-h, x+8, top+60);
      ctx.fill();
    }

    const flowerCount = Math.floor(canvas.width / 45);
    for (let i=0;i<flowerCount;i++) {
      const fx = 30 + i*45 + Math.sin((bgSeed+i)*0.5)*6;
      drawFlower(fx, top + 40 + (i%2*4));
    }
  }

  function drawFlower(x, y) {
    ctx.strokeStyle = '#2F8A3E';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(x, y);
    ctx.lineTo(x, y-12);
    ctx.stroke();
    ctx.fillStyle = '#FFB6C1';
    for (let i=0;i<5;i++) {
      const ang = i*(Math.PI*2/5);
      ctx.beginPath();
      ctx.ellipse(x + Math.cos(ang)*4, y-14 + Math.sin(ang)*3, 3, 4, ang, 0, Math.PI*2);
      ctx.fill();
    }
    ctx.fillStyle = '#FFD54A';
    ctx.beginPath(); ctx.arc(x, y-14, 2.2, 0, Math.PI*2); ctx.fill();
  }

  function roundRectFillPixels(x, y, w, h, r) {
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.arcTo(x + w, y, x + w, y + h, r);
    ctx.arcTo(x + w, y + h, x, y + h, r);
    ctx.arcTo(x, y + h, x, y, r);
    ctx.arcTo(x, y, x + w, y, r);
    ctx.closePath();
  }

  function roundRectFill(x, y, w, h, r) {
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.arcTo(x + w, y, x + w, y + h, r);
    ctx.arcTo(x + w, y + h, x, y + h, r);
    ctx.arcTo(x, y + h, x, y, r);
    ctx.arcTo(x, y, x + w, y, r);
    ctx.closePath();
    ctx.fill();
  }

  function draw(gameOverFlag = false) {
    drawBackground();

    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    for (let i=0;i<=COLS;i++){
      ctx.beginPath(); ctx.moveTo(i*TILE,0); ctx.lineTo(i*TILE,canvas.height); ctx.stroke();
    }
    for (let j=0;j<=ROWS;j++){
      ctx.beginPath(); ctx.moveTo(0,j*TILE); ctx.lineTo(canvas.width,j*TILE); ctx.stroke();
    }

    if (food) {
      const fx = food.x * TILE;
      const fy = food.y * TILE;
      ctx.fillStyle = 'rgba(0,0,0,0.18)';
      ctx.beginPath(); ctx.ellipse(fx+TILE/2, fy+TILE-3, TILE*0.36, TILE*0.14, 0, 0, Math.PI*2); ctx.fill();
      ctx.fillStyle = '#e74c3c';
      roundRectFill(fx+3, fy+3, TILE-6, TILE-6, 6);
      ctx.fillStyle = 'rgba(255,255,255,0.6)';
      ctx.beginPath(); ctx.ellipse(fx+TILE*0.7, fy+TILE*0.35, TILE*0.12, TILE*0.08, 0, 0, Math.PI*2); ctx.fill();
    }

    for (let i=snake.length-1;i>=0;i--) {
      const s = snake[i];
      const sx = s.x * TILE;
      const sy = s.y * TILE;
      if (i === 0) {
        const grad = ctx.createLinearGradient(sx, sy, sx+TILE, sy+TILE);
        grad.addColorStop(0, '#7EE6A9');
        grad.addColorStop(1, '#2ECC71');
        ctx.fillStyle = grad;
        roundRectFill(sx+1, sy+1, TILE-2, TILE-2, 6);

        let eyeOffsetX = TILE * 0.65;
        let eyeOffsetY = TILE * 0.35;
        if (dir.x === -1) eyeOffsetX = TILE * 0.35;
        if (dir.y === 1) eyeOffsetY = TILE * 0.65;
        if (dir.y === -1) eyeOffsetY = TILE * 0.35;

        ctx.fillStyle = '#fff';
        ctx.beginPath(); ctx.ellipse(sx+eyeOffsetX, sy+eyeOffsetY, TILE*0.11, TILE*0.15, 0, 0, Math.PI*2); ctx.fill();
        ctx.fillStyle = '#1b1b1b';
        ctx.beginPath(); ctx.ellipse(sx+eyeOffsetX + (dir.x*1), sy+eyeOffsetY + (dir.y*1), TILE*0.05, TILE*0.07, 0, 0, Math.PI*2); ctx.fill();
      } else {
        ctx.fillStyle = i%2 ? '#27ae60' : '#2ecc71';
        roundRectFill(sx+2, sy+2, TILE-4, TILE-4, 5);
      }
    }

    if (gameOverFlag) {
      ctx.fillStyle = 'rgba(0,0,0,0.5)';
      ctx.fillRect(0, canvas.height/2 - 40, canvas.width, 80);
      ctx.fillStyle = '#fff';
      ctx.font = '20px Arial';
      ctx.textAlign = 'center';
      ctx.fillText('游戏结束 — 按空格重启', canvas.width/2, canvas.height/2 + 7);
    }
  }

  window.addEventListener('keydown', e => {
    if (e.key === 'ArrowUp' || e.key === 'w') nextDir = {x:0,y:-1};
    else if (e.key === 'ArrowDown' || e.key === 's') nextDir = {x:0,y:1};
    else if (e.key === 'ArrowLeft' || e.key === 'a') nextDir = {x:-1,y:0};
    else if (e.key === 'ArrowRight' || e.key === 'd') nextDir = {x:1,y:0};
    else if (e.code === 'Space') {
      if (!running) reset();
      else { running = !running; if (running) timerId = setInterval(tick, speed); else clearInterval(timerId); }
      e.preventDefault();
    }
  });

  canvas.addEventListener('click', () => { if (!running) reset(); });

  reset();
})();
</script>
</body>
</html>
