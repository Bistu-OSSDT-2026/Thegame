<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8" />
<title>贪吃蛇小游戏</title>

<style>
/*页面基础样式配置*/
body { 
	display: flex;                    /* 使用 Flex 布局把内容垂直居中 */
	align-items: center;              /* 垂直居中 */
	justify-content: center;          /* 水平居中 */
	height: 100vh;                    /* 占满整个浏览器视口高度 */
	margin: 0; 
      
/* 网页大背景*/
/*75% 透明度黑色线性渐变滤镜，底层叠加背景图片 */
background-image: linear-gradient(rgba(0, 0, 0, 0.75), rgba(0, 0, 0, 0.75)), 
                        url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=1920');
	background-size: cover;                  /* 背景图等比例缩放覆盖屏幕 */
	background-position: center;             /* 背景图居中对齐 */
	color: #eee;                             /* 全局文字浅灰色 */
	font-family: Arial, sans-serif;
	overflow: hidden;                        /* 隐藏浏览器滚动条，防止游戏时意外滚动页面 */
    }
    
#game { 
	background: rgba(20, 20, 20, 0.9);   /* 画布设为半透明深色(红, 绿, 蓝, 透明度)，让网页大背景隐约透出来 */
	border: 2px solid #444;              /* 亮灰色实体边框线，明确地图边界 */
	border-radius: 8px;                  /* 边框圆角 */
	cursor: pointer;                     /* 鼠标悬停在画布上时显示为手型 */
	animation: borderPulse 3s infinite ease-in-out; /* 绑定边缘泛红呼吸灯动画，单次周期3秒，无限循环，平滑淡入淡出效果 */
     }

/* 定义名为borderPulse的边缘泛红呼吸灯动效（CSS阴影）*/
@keyframes borderPulse {
	0% {
        box-shadow: 0 0 15px rgba(231, 76, 60, 0.3), inset 0 0 10px rgba(231, 76, 60, 0.15);/* 0% 状态：较淡的外部红色发光 + 较淡的内部红色发光 */
      		}
	50% {
		box-shadow: 0 0 30px rgba(231, 76, 60, 0.7), inset 0 0 20px rgba(231, 76, 60, 0.4);/* 50% 状态（呼吸高潮）：强烈的外部红色发光 + 明显的内部边缘泛红，起到警示边界的作用 */
      		}
	100% {
        	box-shadow: 0 0 15px rgba(231, 76, 60, 0.3), inset 0 0 10px rgba(231, 76, 60, 0.15);/* 100% 状态：恢复到较淡光晕 */
      		}
    }

/* 顶部的游戏操作提示文字样式 */
.info { 
	position: absolute; 
	top: 12px; 
	left: 12px; 
	color: #bbb; 
	font-size: 14px; 
	letter-spacing: 1px;                       /* 字间距增加 1px */
  	text-shadow: 1px 1px 3px rgba(0,0,0,0.8);  /* 增加文字黑影，确保在复杂背景下清晰可见 */
}

/* 底部的记分板区域样式 */
.footer { 
	position: fixed; 
	bottom: 10px; 
	left: 10px; 
	color: #999; 
	font-size: 13px; 
	text-shadow: 1px 1px 3px rgba(0,0,0,0.8); 
}

/* 分数数字加亮强调 */
#score { 
	color: #2ecc71;        /* 绿色 */
	font-weight: bold; 
	font-size: 16px; 
	}
  </style>
</head>
<body>

<div class="info">按方向键/WASD移动 • 空格键暂停/重启</div>
<canvas id="game" width="600" height="600"></canvas>
<div class="footer">Score: <span id="score">0</span></div>

<script>
	// 使用 IIFE (立即执行函数表达式) 包装整个游戏，避免变量污染全局命名空间
(() => {
	// 获取核心 DOM 元素及 Canvas 2D 绘图上下文
	const canvas = document.getElementById('game');
	const ctx = canvas.getContext('2d');
	const scoreEl = document.getElementById('score');
	// 地图核心参数配置
  	const TILE = 20;                    // 每个格子的像素大小 (20x20 像素)
  	const COLS = canvas.width / TILE;   // 计算一共有多少列格子 (600 / 20 = 30列)
  	const ROWS = canvas.height / TILE;  // 计算一共有多少行格子 (600 / 20 = 30行)

	// 游戏运行时状态变量定义
  	let snake;                  // 蛇身数组，存储每一节的坐标对象，形如：[{x:15, y:15}, {x:14, y:15}]
  	let dir;                    // 当前这一帧蛇正在移动的方向向量，例：向右为 {x:1, y:0}
  	let nextDir;                // 玩家通过键盘按下的下一个方向向量，将在下一帧(tick)被消化
  	let food;                   // 食物的坐标对象，形如：{x: 5, y: 10}
  	let running;                // 游戏运行总开关：true 代表游戏进行中/暂停，false 代表游戏结束 Game Over
  	let isPaused = false;       // 游戏暂停状态：true 代表当前被空格键暂停了
  	let score;                  // 玩家当前得分
  	let speed;                  // 游戏核心定时器的帧间隔时间（单位：毫秒，数值越小蛇跑得越快）
  	let timerId;                // 存储 setInterval 返回的定时器 ID，用于清除和重启循环
  	let turnActionValid = true; // 按键锁/转向标志位：在一帧内如果已经改过方向，设为 false，防止极限手速下快速按键导致的“自撞” Bug

/**
   * 游戏重置与初始化函数
   * 负责清空状态、生成长身体的蛇、重置分数、启动定时器
   */
function reset() {
	// 1. 计算画布正中心点的坐标，作为初始蛇头位置
    const headX = Math.floor(COLS / 2);
    const headY = Math.floor(ROWS / 2);
	// 2. 初始化蛇身：默认生成 4 个节长（1个蛇头 + 3个身体）。x 坐标依次递减，使其横向在中间排开
    snake = [
      { x: headX,     y: headY }, // 蛇头坐标
      { x: headX - 1, y: headY }, // 身体节1
      { x: headX - 2, y: headY }, // 身体节2
      { x: headX - 3, y: headY }  // 身体节3
    ];

    dir = {x: 1, y: 0};             // 默认初始移动方向：向右
    nextDir = dir;					// 下一帧方向同步初始化
    placeFood();					// 在地图上随机投放第一个食物
    running = true;					// 启动运行状态
    isPaused = false;				// 确保没有处于暂停
    score = 0;						// 分数归零
    speed = 120;					// 初始移动延迟定为 120 毫秒一次
    scoreEl.textContent = score;    // 更新页面上显示的数字
    startTimer();					// 开启游戏主循环时钟
  }

  function startTimer() {
    if (timerId) clearInterval(timerId);
    timerId = setInterval(tick, speed);
  }

  function placeFood() {
    while (true) {
      const pos = { x: Math.floor(Math.random()*COLS), y: Math.floor(Math.random()*ROWS) };
      if (!snake.some(s => s.x === pos.x && s.y === pos.y)) {
        food = pos;
        return;
      }
    }
  }

  function tick() {
    if (!(nextDir.x === -dir.x && nextDir.y === -dir.y)) {
      dir = nextDir;
    }
    turnActionValid = true; 

    const head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };

    if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS || 
        snake.some(s => s.x === head.x && s.y === head.y)) {
      gameOver();
      return;
    }

    snake.unshift(head);

    if (head.x === food.x && head.y === food.y) {
      score += 10;
      scoreEl.textContent = score;
      placeFood();
      speed = Math.max(50, speed - 3); 
      startTimer();
    } else {
      snake.pop();
    }

    draw();
  }

  function gameOver() {
    running = false;
    clearInterval(timerId);
    draw();
  }

  function draw() {
    ctx.fillStyle = '#121212';
    ctx.fillRect(0,0,canvas.width,canvas.height);

    ctx.strokeStyle = 'rgba(255,255,255,0.03)';
    for (let i=0; i<=COLS; i++){
      ctx.beginPath(); ctx.moveTo(i*TILE,0); ctx.lineTo(i*TILE,canvas.height); ctx.stroke();
    }
    for (let j=0; j<=ROWS; j++){
      ctx.beginPath(); ctx.moveTo(0,j*TILE); ctx.lineTo(canvas.width,j*TILE); ctx.stroke();
    }

    ctx.fillStyle = '#e74c3c';
    roundRectFill(food.x*TILE, food.y*TILE, TILE, TILE, 4);

    for (let i=0; i<snake.length; i++) {
      const s = snake[i];
      ctx.fillStyle = (i === 0) ? '#2ecc71' : '#27ae60';
      roundRectFill(s.x*TILE, s.y*TILE, TILE, TILE, 4);
    }

    if (!running || isPaused) {
      ctx.fillStyle = 'rgba(0,0,0,0.6)';
      ctx.fillRect(0, canvas.height/2 - 40, canvas.width, 80);
      ctx.fillStyle = '#fff';
      ctx.font = '20px Arial';
      ctx.textAlign = 'center';
      
      if (!running) {
        ctx.fillText('游戏结束 — 按空格重启', canvas.width/2, canvas.height/2 + 7);
      } else if (isPaused) {
        ctx.fillText('游戏暂停 — 按空格继续', canvas.width/2, canvas.height/2 + 7);
      }
    }
  }

  function roundRectFill(x, y, w, h, r) {
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.arcTo(x + w, y, x + w, y + h, r);
    ctx.arcTo(x + w, y + h, x, y + h, r);
    ctx.arcTo(x, y + h, x, y, r);
    ctx.arcTo(x, y, x + w, y, r);
    ctx.closePath();
    ctx.fill();
  }

  window.addEventListener('keydown', e => {
    if (!turnActionValid && ['ArrowUp','w','ArrowDown','s','ArrowLeft','a','ArrowRight','d'].includes(e.key)) {
      return;
    }

    if ((e.key === 'ArrowUp' || e.key === 'w') && dir.y === 0) { nextDir = {x:0,y:-1}; turnActionValid = false; }
    else if ((e.key === 'ArrowDown' || e.key === 's') && dir.y === 0) { nextDir = {x:0,y:1}; turnActionValid = false; }
    else if ((e.key === 'ArrowLeft' || e.key === 'a') && dir.x === 0) { nextDir = {x:-1,y:0}; turnActionValid = false; }
    else if ((e.key === 'ArrowRight' || e.key === 'd') && dir.x === 0) { nextDir = {x:1,y:0}; turnActionValid = false; }
    else if (e.code === 'Space') {
      e.preventDefault();
      if (!running) {
        reset();
      } else { 
        isPaused = !isPaused; 
        if (isPaused) {
          clearInterval(timerId);
          draw(); 
        } else {
          startTimer();
        }
      }
    }
  });

  canvas.addEventListener('click', () => { if (!running) reset(); });

  reset();
})();
</script>
</body>
</html>
